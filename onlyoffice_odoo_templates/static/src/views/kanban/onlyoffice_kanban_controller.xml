<templates>
  <t t-name="onlyoffice_odoo_templates.KanbanView.Buttons" t-inherit="web.KanbanView" t-inherit-mode="primary">
    <xpath expr="//button[hasclass('o-kanban-button-new')]" position="after">
      <button class="btn btn-secondary ms-1" t-on-click="() => this.openFormGallery()" style="text-wrap: nowrap;">
        Open Document templates
      </button>
      <button class="btn btn-secondary ms-1" t-on-click="() => this.help()"> Help </button>
    </xpath>
  </t>
</templates>
