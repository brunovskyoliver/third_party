<odoo>
  <record id="view_onlyoffice_form" model="ir.ui.view">
    <field name="name">onlyoffice.odoo.templates.form</field>
    <field name="model">onlyoffice.odoo.templates</field>
    <field name="arch" type="xml">
      <form string="Create template">
        <sheet>
          <div class="oe_button_box" name="button_box" groups="base.group_system">
            <button
              name="associated_report"
              type="object"
              invisible="not report_id"
              icon='fa-code'
              class="oe_stat_button"
            >
              <div class="o_field_widget o_stat_info">
                <span class="o_stat_text">Report</span>
              </div>
            </button>
            <button
              name="create_action"
              type="object"
              invisible="report_id"
              icon="fa-plus-square"
              class="oe_stat_button"
            >
              <div class="o_field_widget o_stat_info">
                <span class="o_stat_text">Create associated report</span>
              </div>
            </button>
            <button
              name="unlink_action"
              type="object"
              invisible="not report_id"
              icon="fa-minus-square"
              class="oe_stat_button"
            >
              <div class="o_field_widget o_stat_info">
                <span class="o_stat_text">Remove associated report</span>
              </div>
            </button>
          </div>
          <group string="Template creation">
            <div class="text-muted" colspan="2"> Use this form to create a new fillable PDF template
              for your Odoo modules. Start by entering a <span class="fw-bolder">name </span> for
              your template to easily identify it later in the ONLYOFFICE Templates list. </div>
            <div class="text-muted" colspan="2"> Choose the <span class="fw-bolder">Odoo module </span>
              (e.g., Employee, Invoice, Sales Order) that the template will be linked to. The chosen
              model defines the data fields available for automatic form filling. </div>
            <field name="name" required="1" />
            <field
              name="template_model_id"
              options="{'no_create': True, 'no_create_edit':True, 'no_open':True}"
              help="Model for which the template is being created."
              required="1"
            />
            <field name="template_model_related_name" invisible="1" />
            <field name="template_model_model" invisible="1" />
            <field name="hide_file_field" invisible="1" />
            <field name="report_id" invisible="1" />
          </group>
          <group string="Template uploading" invisible="hide_file_field">
            <div class="text-muted" colspan="2"> If you already have a <span class="fw-bolder">prepared
              PDF file</span> with fillable fields, you can upload it here </div>
            <field
              name="file"
              options="{'accepted_file_extensions': '.pdf', 'attachment': False}"
              help="Select an existing template. Leave the field blank to create a blank template."
            />
          </group>
          <group>
            <div colspan="2">
              <div class="text-muted">
                Once you've saved the template, return to the ONLYOFFICE Templates list.
              </div>
              <div class="text-muted">
                Locate your newly created template and set up the connections between the form
                fields in the ONLYOFFICE editor and the corresponding data fields from the selected
                Odoo model.
              </div>
            </div>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_onlyoffice_kanban_search" model="ir.ui.view">
    <field name="name">onlyoffice.odoo.templates.kanban.search</field>
    <field name="model">onlyoffice.odoo.templates</field>
    <field name="arch" type="xml">
      <search>
        <field name="name" />
        <field name="template_model_name" />
        <group>
          <filter string="Model" name="template_model_id" context="{'group_by': 'template_model_id'}" />
        </group>
        <searchpanel>
          <field name="template_model_id" string="Model" enable_counters="1" />
        </searchpanel>
      </search>
    </field>
  </record>

  <record id="view_onlyoffice_kanban" model="ir.ui.view">
    <field name="name">onlyoffice.odoo.templates.kanban</field>
    <field name="model">onlyoffice.odoo.templates</field>
    <field name="arch" type="xml">
      <kanban js_class="onlyoffice_kanban">
        <field name="id" />
        <field name="attachment_id" />
        <field name="mimetype" />
        <field name="create_uid" />
        <field name="create_date" />
        <field name="name" />
        <field name="template_model_name" />
        <field name="template_model_related_name" />
        <field name="template_model_model" />
        <templates>
          <t t-name="menu">
            <a t-if="widget.editable" type="open" class="dropdown-item">Edit</a>
            <a t-if="widget.deletable" type="delete" class="dropdown-item">Delete</a>
            <a
              t-attf-href="/web/content/ir.attachment/#{record.attachment_id.raw_value}/datas?download=true"
              download=""
              class="dropdown-item"
            >Download</a>
          </t>
          <t t-name="card" class="o_kanban_attachment flex-row">
            <aside class="o_kanban_image m-1">
              <div class="o_kanban_image_wrapper d-flex align-items-center justify-content-center">
                <div class="o_image o_image_thumbnail" t-att-data-mimetype="record.mimetype.value" />
              </div>
            </aside>
            <main class="ms-1">
              <div class="o_kanban_details_wrapper d-flex flex-column">
                <field name="name" class="text-truncate fw-bold fs-5" />
                <div class="d-flex flex-grow-1 align-items-center">
                  <t t-if="template_model_related_name">
                    <field name="template_model_related_name" widget="badge" />
                  </t>
                  <t t-else="">
                    <field name="template_model_name" widget="badge" />
                  </t>
                </div>
                <div class="d-flex justify-content-between">
                  <field name="create_date" widget="date" />
                  <field name="create_uid" widget="many2one_avatar_user" />
                </div>
              </div>
            </main>
          </t>
        </templates>
      </kanban>
    </field>
  </record>

  <record id="action_onlyoffice_template_editor" model="ir.actions.client">
    <field name="name">Template Editor Action</field>
    <field name="tag">onlyoffice_template_editor</field>
  </record>

  <record id="view_onlyoffice_list" model="ir.ui.view">
    <field name="name">onlyoffice.odoo.templates.list</field>
    <field name="model">onlyoffice.odoo.templates</field>
    <field name="arch" type="xml">
      <list create="true">
        <field name="name" />
        <field name="template_model_id" />
        <field name="template_model_related_name" column_invisible="1" />
        <field name="template_model_model" string="Technical Name" />
        <field name="mimetype" column_invisible="1" />
        <field name="attachment_id" />
        <field name="create_uid" />
        <field name="create_date" />
        <button name="open_template_editor" type="object" string="Edit Template" icon="fa-edit" class="btn-primary" />
      </list>
    </field>
  </record>

  <record model="ir.actions.act_window" id="action_onlyoffice_odoo_templates">
    <field name="name">ONLYOFFICE Templates</field>
    <field name="res_model">onlyoffice.odoo.templates</field>
    <field name="view_mode">kanban,list,form</field>
    <field name="search_view_id" ref="view_onlyoffice_kanban_search" />
  </record>

  <menuitem
    id="onlyoffice_menu"
    name="ONLYOFFICE Templates"
    web_icon="onlyoffice_odoo_templates,static/description/icon.png"
    sequence="30"
    groups="onlyoffice_odoo_templates.group_onlyoffice_odoo_templates_user,onlyoffice_odoo_templates.group_onlyoffice_odoo_templates_admin"
    action="action_onlyoffice_odoo_templates"
  />

  <menuitem
    id="onlyoffice_submenu"
    name="Templates"
    parent="onlyoffice_menu"
    action="action_onlyoffice_odoo_templates"
  />
</odoo>
