<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="category_announcement" model="ir.module.category">
        <field name="name">Oznamy</field>
    </record>

    <record id="privilege_announcement" model="res.groups.privilege">
        <field name="name">Správa oznamov</field>
        <field name="category_id" ref="category_announcement"/>
    </record>

    <record id="announcement_manager" model="res.groups">
        <field name="name">Správca oznamov</field>
        <field name="privilege_id" ref="privilege_announcement"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Používatelia môžu spravovať a konfigurovať oznamy.</field>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <data noupdate="1">
        <record id="announcement_log_rule" model="ir.rule">
            <field name="name">Log oznamov podľa používateľa</field>
            <field name="model_id" ref="model_announcement_log"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="perm_read" eval="False"/>
        </record>

        <record id="announcement_log_manager_rule" model="ir.rule">
            <field name="name">Manažérsky prístup k logu oznamov</field>
            <field name="model_id" ref="model_announcement_log"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('announcement_manager'))]"/>
        </record>

        <record id="announcement_user_rule" model="ir.rule">
            <field name="name">Používateľské oznamy</field>
            <field name="model_id" ref="model_announcement"/>
            <field name="domain_force">[('active', '=', True), ('allowed_user_ids', 'in', user.id), ('in_date', '=', True)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="announcement_manager_rule" model="ir.rule">
            <field name="name">Správcovia oznamov</field>
            <field name="model_id" ref="model_announcement"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('announcement_manager'))]"/>
        </record>
    </data>

    <record id="rule_multi_company_announcement_tag" model="ir.rule">
        <field name="name">Tag oznamu pre viac spoločností</field>
        <field name="model_id" ref="model_announcement_tag"/>
        <field name="domain_force">[('company_id', 'in', [False] + company_ids)]</field>
    </record>
</odoo>
